## Copy to .env and fill in
# Provider: groq | gemini | openai | stub
LLM_PROVIDER=groq

# Groq (OpenAI-compatible, fast + generous free tier)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (only if LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# 1 = force deterministic stub generator (eval works offline). Overrides LLM_PROVIDER.
STUB_LLM=0

# Server
PORT=8787
